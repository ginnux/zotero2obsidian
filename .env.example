# Copy this file to .env and adjust the values for your machine.

# Absolute path to your Obsidian vault.
Z2O_VAULT="/absolute/path/to/your/ObsidianVault"

# Paths below may be relative to Z2O_VAULT or absolute.
Z2O_NOTES_DIR="papers/notes"
Z2O_INDEX_DIR="papers/index"
Z2O_SUMMARY_DIR="knowledge/Summary"
Z2O_TEMP_DIR=".paper-cache"
Z2O_ASSETS_DIR="assets"

# Optional runtime overrides.
BBT_JSON_RPC_URL="http://localhost:23119/better-bibtex/json-rpc"
# PYTHON="/opt/miniconda3/envs/paper/bin/python"

# CLI note generator. Default is a deterministic local draft; the read-zotero-paper
# skill writes formal notes with the current Agent after prepare.sh finishes.
# Z2O_NOTE_GENERATOR="local"

# Extraction backend: auto/mineru try MinerU first when a token exists, then
# fall back to PyMuPDF. Use "mineru-strict" to require MinerU, or "pymupdf"
# to disable MinerU.
Z2O_EXTRACTOR="auto"

# MinerU precise parsing API.
# MINERU_API_TOKEN="your-token"
MINERU_API_BASE="https://mineru.net/api/v4"
MINERU_MODEL_VERSION="vlm"
MINERU_LANGUAGE="ch"
MINERU_ENABLE_FORMULA="true"
MINERU_ENABLE_TABLE="true"
MINERU_IS_OCR="false"
MINERU_POLL_INTERVAL="5"
MINERU_TIMEOUT="900"
# MINERU_PAGE_RANGES="1-5"
